# Exclude development and tooling files; keep build output and runtime assets only

# Node modules — NOT needed at runtime (extension is fully bundled via esbuild)
node_modules/**

# Squad team tooling (not needed at runtime)
.squad/**

# Individual compiled JS — NOT needed (extension is bundled into out/extension.js + out/webview.js)
out/src/**
out/test/**

# Editor and workspace settings
.vscode/**
.vscode-test/**

# Git and CI metadata
.git/**
.gitignore
.gitattributes
.github/**

# BMAD / project tooling artifacts (not needed at runtime)
_bmad/**
_bmad-output/**

# Documentation and project tooling (not needed at runtime)
docs/**
scripts/**
presentation/**
infrastructure/**

# Source and tests (compiled output in out/** is what we ship)
src/**
test/**
tests/**
coverage/**

# TypeScript sources and maps (exclude if present; use compiled JS instead)
**/*.ts
**/*.tsx
**/*.map
**/*.tsbuildinfo

# Common local tooling / configuration files
.eslintrc*
.prettierrc*
tsconfig*.json
jest.config.*
webpack.config.*
rollup.config.*
esbuild.config.js
eslint.config.mjs
commitlint.config.js
lefthook.yml
*.code-workspace
npm-output.txt

# Logs and temporary files
npm-debug.log*
yarn-error.log*
*.log
*.tmp

# Note: out/** and media/** are intentionally included —
# out/ contains the bundled extension code, media/ contains runtime assets (icons, fonts).
