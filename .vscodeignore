# Exclude everything that is not needed at runtime.
# esbuild bundles all source + dependencies into out/extension.js and out/webview.js,
# so node_modules and tsc-compiled output are never needed in the VSIX.

# ── Editor / workspace ────────────────────────────────────────────────────────
.vscode/**
.vscode-test/**
*.code-workspace

# ── Version control & CI ──────────────────────────────────────────────────────
.git/**
.gitignore
.gitattributes
.github/**

# ── Source (bundled by esbuild — not needed in VSIX) ─────────────────────────
src/**
test/**
tests/**
coverage/**

# ── TypeScript artefacts ──────────────────────────────────────────────────────
**/*.ts
**/*.tsx
**/*.map
**/*.tsbuildinfo
tsconfig*.json

# ── tsc-compiled output (superseded by esbuild bundles) ──────────────────────
# Keep: out/extension.js, out/webview.js, out/webview/** (static assets)
out/src/**
out/test/**

# ── Node modules (all deps are bundled by esbuild) ───────────────────────────
node_modules/**

# ── Build / release tooling ───────────────────────────────────────────────────
esbuild.config.js
.releaserc.json
.commitlintrc.cjs
commitlint.config.js
eslint.config.mjs
.prettierrc
.nycrc.json
lefthook.yml
.env.template
.mcp.json

# ── Documentation & misc dev files ───────────────────────────────────────────
docs/**
presentation/**
scripts/**
infrastructure/**
AGENTS.md
CHANGELOG.md
CUSTOM-LAYOUT-CONFIGURATION.md

# ── AI team / squad files ─────────────────────────────────────────────────────
.squad/**

# ── Test runner config ────────────────────────────────────────────────────────
.vscode-test.mjs

# ── Logs and temporary files ──────────────────────────────────────────────────
npm-debug.log*
yarn-error.log*
*.log
*.tmp
*.txt

# ── Already-packaged artefacts ────────────────────────────────────────────────
*.vsix
